diff --git a/app/components/valuation-choice.tsx b/app/components/valuation-choice.tsx
new file mode 100644
index 0000000..0a8e5fe
--- /dev/null
+++ b/app/components/valuation-choice.tsx
@@ -0,0 +1,53 @@
+import { LuCheck } from 'react-icons/lu';
+
+interface ValuationChoiceProps {
+  active: boolean;
+  description?: string;
+  icon?: React.ReactNode;
+  label: string;
+  onClick: () => void;
+}
+
+/**
+ * Renders one selectable answer in the valuation questionnaire and exposes the
+ * current selection through `aria-pressed` for assistive technologies.
+ */
+export default function ValuationChoice({
+  active,
+  description,
+  icon,
+  label,
+  onClick,
+}: ValuationChoiceProps) {
+  return (
+    <button
+      className={`flex w-full items-center gap-4 rounded-xl border p-5 text-left transition ${
+        active
+          ? 'border-[#167f73] bg-[#3df5dc]/10 ring-2 ring-[#3df5dc]/25'
+          : 'border-gray-200 hover:border-gray-300 hover:bg-gray-50'
+      }`}
+      type="button"
+      aria-pressed={active}
+      onClick={onClick}
+    >
+      {/* Icons are optional because text-only choices use the same component. */}
+      {icon && (
+        <span className="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white text-[#167f73] shadow-sm">
+          {icon}
+        </span>
+      )}
+      <span className="flex-1">
+        <span className="block font-semibold text-gray-900">{label}</span>
+        {description && <span className="mt-1 block text-sm text-gray-500">{description}</span>}
+      </span>
+      {/* The trailing marker provides a consistent visual selection state. */}
+      <span
+        className={`flex h-5 w-5 shrink-0 items-center justify-center rounded-full border ${
+          active ? 'border-[#167f73] bg-[#167f73] text-white' : 'border-gray-300'
+        }`}
+      >
+        {active && <LuCheck size="13" aria-hidden="true" />}
+      </span>
+    </button>
+  );
+}
diff --git a/app/data/valuation.ts b/app/data/valuation.ts
new file mode 100644
index 0000000..6cec58c
--- /dev/null
+++ b/app/data/valuation.ts
@@ -0,0 +1,53 @@
+export type PropertyType = 'apartment' | 'house';
+export type LocationType = 'rural' | 'small-city' | 'large-city';
+export type ConditionType = 'needs-work' | 'good' | 'renovated';
+
+interface ValuationInput {
+  propertyType: PropertyType;
+  location: LocationType;
+  livingSpace: number;
+  condition: ConditionType;
+}
+
+const locationPrices: Record<LocationType, number> = {
+  rural: 2200,
+  'small-city': 3000,
+  'large-city': 4200,
+};
+
+const conditionFactors: Record<ConditionType, number> = {
+  'needs-work': 0.82,
+  good: 1,
+  renovated: 1.18,
+};
+
+/**
+ * Produces a simple market-value estimate from the selected property details.
+ * The calculation combines a location price per square metre with adjustments
+ * for the property type and its current condition.
+ */
+export function calculatePropertyValue({
+  propertyType,
+  location,
+  livingSpace,
+  condition,
+}: ValuationInput) {
+  const propertyTypeFactor = propertyType === 'house' ? 1.12 : 1;
+  return Math.round(
+    livingSpace *
+      locationPrices[location] *
+      propertyTypeFactor *
+      conditionFactors[condition],
+  );
+}
+
+/**
+ * Formats an estimated property value as a rounded euro amount for the UI.
+ */
+export function formatPropertyValue(value: number) {
+  return new Intl.NumberFormat('en-US', {
+    style: 'currency',
+    currency: 'EUR',
+    maximumFractionDigits: 0,
+  }).format(value);
+}
