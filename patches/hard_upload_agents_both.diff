index 0000000..ff1d82c
--- /dev/null
+++ b/app/data/property-store.ts
@@ -0,0 +1,166 @@
+import { useSyncExternalStore } from 'react';
+import staticExposes from './exposes.json';
+import type { Property } from './properties';
+
+const DATABASE_NAME = 'estate-scout42';
+const DATABASE_VERSION = 1;
+const STORE_NAME = 'properties';
+
+export type LocalPropertyInput = Omit<
+  Property,
+  'id' | 'created_at' | 'source'
+>;
+
+interface StoreSnapshot {
+  properties: Property[];
+  localProperties: Property[];
+  loading: boolean;
+  error: string;
+}
+
+const normalizedStaticProperties: Property[] = (staticExposes as Property[]).map(
+  (property) => ({
+    ...property,
+    source: 'static',
+    images: [property.main_image],
+  }),
+);
+
+let snapshot: StoreSnapshot = {
+  properties: normalizedStaticProperties,
+  localProperties: [],
+  loading: typeof indexedDB !== 'undefined',
+  error: '',
+};
+let initialized = false;
+const listeners = new Set<() => void>();
+
+function emit(nextSnapshot: StoreSnapshot) {
+  snapshot = nextSnapshot;
+  listeners.forEach((listener) => listener());
+}
+
+function getDatabase() {
+  return new Promise<IDBDatabase>((resolve, reject) => {
+    if (typeof indexedDB === 'undefined') {
+      reject(new Error('Local browser storage is unavailable.'));
+      return;
+    }
+
+    const request = indexedDB.open(DATABASE_NAME, DATABASE_VERSION);
+    request.onupgradeneeded = () => {
+      const database = request.result;
+      if (!database.objectStoreNames.contains(STORE_NAME)) {
+        database.createObjectStore(STORE_NAME, { keyPath: 'id' });
+      }
+    };
+    request.onsuccess = () => resolve(request.result);
+    request.onerror = () =>
+      reject(request.error ?? new Error('Could not open local browser storage.'));
+  });
+}
+
+function requestResult<T>(request: IDBRequest<T>) {
+  return new Promise<T>((resolve, reject) => {
+    request.onsuccess = () => resolve(request.result);
+    request.onerror = () =>
+      reject(request.error ?? new Error('Local browser storage request failed.'));
+  });
+}
+
+function readableStorageError(error: unknown) {
+  if (error instanceof DOMException && error.name === 'QuotaExceededError') {
+    return 'Your browser storage is full. Remove a local listing or use smaller images.';
+  }
+
+  return error instanceof Error
+    ? error.message
+    : 'Local listings could not be accessed.';
+}
+
+async function readLocalProperties() {
+  const database = await getDatabase();
+  try {
+    const transaction = database.transaction(STORE_NAME, 'readonly');
+    const properties = await requestResult(
+      transaction.objectStore(STORE_NAME).getAll() as IDBRequest<Property[]>,
+    );
+    return properties.sort((first, second) =>
+      (second.created_at ?? '').localeCompare(first.created_at ?? ''),
+    );
+  } finally {
+    database.close();
+  }
+}
+
+export async function refreshProperties() {
+  emit({ ...snapshot, loading: true, error: '' });
+
+  try {
+    const localProperties = await readLocalProperties();
+    emit({
+      properties: [...localProperties, ...normalizedStaticProperties],
+      localProperties,
+      loading: false,
+      error: '',
+    });
+  } catch (error) {
+    emit({
+      ...snapshot,
+      loading: false,
+      error: readableStorageError(error),
+    });
+  }
+}
+
+function initialize() {
+  if (initialized) return;
+  initialized = true;
+  void refreshProperties();
+}
+
+export async function createLocalProperty(input: LocalPropertyInput) {
+  const property: Property = {
+    ...input,
+    id: crypto.randomUUID(),
+    created_at: new Date().toISOString(),
+    source: 'local',
+  };
+  const database = await getDatabase();
+
+  try {
+    const transaction = database.transaction(STORE_NAME, 'readwrite');
+    await requestResult(transaction.objectStore(STORE_NAME).add(property));
+    await refreshProperties();
+    return property;
+  } catch (error) {
+    throw new Error(readableStorageError(error), { cause: error });
+  } finally {
+    database.close();
+  }
+}
+
+export async function deleteLocalProperty(id: string) {
+  const database = await getDatabase();
+
+  try {
+    const transaction = database.transaction(STORE_NAME, 'readwrite');
+    await requestResult(transaction.objectStore(STORE_NAME).delete(id));
+    await refreshProperties();
+  } catch (error) {
+    throw new Error(readableStorageError(error), { cause: error });
+  } finally {
+    database.close();
+  }
+}
+
+export function usePropertyStore() {
+  initialize();
+  return useSyncExternalStore(
+    (listener) => {
+      listeners.add(listener);
+      return () => listeners.delete(listener);
+    },
+    () => snapshot,
+  );
+}
