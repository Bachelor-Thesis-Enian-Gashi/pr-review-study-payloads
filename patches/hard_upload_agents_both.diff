+++ b/app/src/routes/CreateExpose.tsx
@@ -0,0 +1,525 @@
+import { useState } from 'react';
+import {
+  LuArrowLeft,
+  LuArrowRight,
+  LuCheck,
+  LuCircleCheck,
+  LuHousePlus,
+  LuImages,
+} from 'react-icons/lu';
+import { useNavigate } from 'react-router-dom';
+import ImageUpload from '../../components/image-upload';
+import Navbar from '../../components/navbar';
+import {
+  createLocalProperty,
+  type LocalPropertyInput,
+} from '../../data/property-store';
+import { getPropertySlug, type UploadImage } from '../../data/properties';
+
+const steps = ['Basics', 'Details', 'Images', 'Preview'];
+const propertyTypes = ['Apartment', 'House', 'Loft', 'Penthouse', 'Studio'];
+
+interface FormState {
+  name: string;
+  rentWarm: string;
+  size: string;
+  rooms: string;
+  address: string;
+  description: string;
+  type: string;
+  floor: string;
+  availableFrom: string;
+  petsAllowed: boolean;
+  internetSpeed: string;
+}
+
+const initialForm: FormState = {
+  name: '',
+  rentWarm: '',
+  size: '',
+  rooms: '',
+  address: '',
+  description: '',
+  type: 'Apartment',
+  floor: '0',
+  availableFrom: '',
+  petsAllowed: false,
+  internetSpeed: '',
+};
+
+function today() {
+  const date = new Date();
+  const offset = date.getTimezoneOffset();
+  return new Date(date.getTime() - offset * 60_000).toISOString().slice(0, 10);
+}
+
+export default function CreateExpose() {
+  const navigate = useNavigate();
+  const [step, setStep] = useState(0);
+  const [form, setForm] = useState(initialForm);
+  const [images, setImages] = useState<UploadImage[]>([]);
+  const [errors, setErrors] = useState<Record<string, string>>({});
+  const [submitError, setSubmitError] = useState('');
+  const [publishing, setPublishing] = useState(false);
+
+  const updateField = <K extends keyof FormState>(field: K, value: FormState[K]) => {
+    setForm((current) => ({ ...current, [field]: value }));
+    setErrors((current) => ({ ...current, [field]: '' }));
+  };
+
+  const validateStep = (stepToValidate: number) => {
+    const nextErrors: Record<string, string> = {};
+
+    if (stepToValidate === 0) {
+      if (form.name.trim().length < 8) {
+        nextErrors.name = 'Use at least 8 characters for the listing title.';
+      }
+      if (!form.address.includes(',') || form.address.trim().length < 10) {
+        nextErrors.address = 'Enter a complete address including city.';
+      }
+      if (form.description.trim().length < 40) {
+        nextErrors.description = 'Describe the property in at least 40 characters.';
+      }
+    }
+
+    if (stepToValidate === 1) {
+      const numericChecks = [
+        ['rentWarm', Number(form.rentWarm), 1, 100_000],
+        ['size', Number(form.size), 1, 10_000],
+        ['rooms', Number(form.rooms), 1, 100],
+        ['floor', Number(form.floor), 0, 200],
+        ['internetSpeed', Number(form.internetSpeed), 1, 100_000],
+      ] as const;
+
+      numericChecks.forEach(([field, value, minimum, maximum]) => {
+        if (!Number.isFinite(value) || value < minimum || value > maximum) {
+          nextErrors[field] = `Enter a value between ${minimum} and ${maximum.toLocaleString('en-US')}.`;
+        }
+      });
+
+      if (!form.availableFrom || form.availableFrom < today()) {
+        nextErrors.availableFrom = 'Choose today or a future date.';
+      }
+    }
+
+    if (stepToValidate === 2 && images.length === 0) {
+      nextErrors.images = 'Add at least one property image.';
+    }
+
+    setErrors(nextErrors);
+    return Object.keys(nextErrors).length === 0;
+  };
+
+  const goForward = () => {
+    if (!validateStep(step)) return;
+    setStep((current) => Math.min(current + 1, steps.length - 1));
+    window.scrollTo({ top: 0, behavior: 'smooth' });
+  };
+
+  const publish = async () => {
+    if (publishing) return;
+    setPublishing(true);
+    setSubmitError('');
+
+    const imageData = images.map((image) => image.dataUrl);
+    const property: LocalPropertyInput = {
+      name: form.name.trim(),
+      rent_warm: Number(form.rentWarm),
+      size_m2: Number(form.size),
+      rooms: Number(form.rooms),
+      address: form.address.trim(),
+      main_image: imageData[0],
+      images: imageData,
+      description: form.description.trim(),
+      type: form.type,
+      floor: Number(form.floor),
+      available_for_pickup_starting: form.availableFrom,
+      pets_allowed: form.petsAllowed,
+      internet_speed_mbit: Number(form.internetSpeed),
+    };
+
+    try {
+      const createdProperty = await createLocalProperty(property);
+      navigate(`/exposes/${getPropertySlug(createdProperty)}`);
+    } catch (error) {
+      setSubmitError(
+        error instanceof Error ? error.message : 'The listing could not be published.',
+      );
+      setPublishing(false);
+    }
