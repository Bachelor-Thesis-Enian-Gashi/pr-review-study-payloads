+import { LuCirclePlus, LuHouse, LuTrash2 } from 'react-icons/lu';
+import Expose from '../../components/expose';
+import Navbar from '../../components/navbar';
+import {
+  deleteLocalProperty,
+  usePropertyStore,
+} from '../../data/property-store';
+
+export default function MyExposes() {
+  const { localProperties, loading, error } = usePropertyStore();
+  const [deletingId, setDeletingId] = useState('');
+  const [actionError, setActionError] = useState('');
+
+  const removeProperty = async (id: string, name: string) => {
+    if (!window.confirm(`Delete “${name}”? This cannot be undone.`)) return;
+    setDeletingId(id);
+    setActionError('');
+
+    try {
+      await deleteLocalProperty(id);
+    } catch (deleteError) {
+      setActionError(
+        deleteError instanceof Error ? deleteError.message : 'The listing could not be deleted.',
+      );
+    } finally {
+      setDeletingId('');
+    }
+  };
+
+  return (
+    <main className="min-h-screen bg-[#f4f6f7]">
+      <Navbar resultsPage />
+      <section className="mx-auto max-w-[1200px] px-6 py-10">
+        <div className="mb-8 flex flex-wrap items-center justify-between gap-5">
+          <div>
+            <h1 className="text-3xl font-semibold text-gray-950">My listings</h1>
+            <p className="mt-2 text-sm text-gray-500">
+              Manage properties saved in this browser.
+            </p>
+          </div>
+          <a
+            className="inline-flex items-center gap-2 rounded-lg bg-[#3df5dc] px-5 py-3 text-sm font-semibold text-gray-950 transition hover:bg-[#2de0ca]"
+            href="/exposes/new"
+          >
+            <LuCirclePlus aria-hidden="true" />
+            Add property
+          </a>
+        </div>
+
+        {(error || actionError) && (
+          <p className="mb-6 rounded-xl bg-red-50 px-5 py-4 text-sm text-red-700" role="alert">
+            {actionError || error}
+          </p>
+        )}
+
+        {loading && localProperties.length === 0 ? (
+          <div className="rounded-2xl bg-white px-6 py-16 text-center shadow-sm">
+            <p className="text-sm text-gray-500">Loading your listings…</p>
+          </div>
+        ) : localProperties.length > 0 ? (
+          <div className="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
+            {localProperties.map((property) => (
+              <article className="rounded-2xl bg-white p-4 shadow-sm" key={property.id}>
+                <Expose props={property} />
+                <button
+                  className="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-red-100 px-4 py-2.5 text-sm font-medium text-red-600 transition hover:bg-red-50 disabled:cursor-wait disabled:opacity-50"
+                  type="button"
+                  onClick={() => void removeProperty(property.id ?? '', property.name)}
+                  disabled={deletingId === property.id}
+                >
+                  <LuTrash2 aria-hidden="true" />
+                  {deletingId === property.id ? 'Deleting…' : 'Delete listing'}
+                </button>
+              </article>
+            ))}
+          </div>
+        ) : (
+          <div className="rounded-2xl border border-gray-200 bg-white px-6 py-16 text-center shadow-sm">
+            <span className="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#3df5dc]/20 text-[#167f73]">
+              <LuHouse size="25" aria-hidden="true" />
+            </span>
+            <h2 className="mt-5 text-xl font-semibold text-gray-950">No local listings yet</h2>
+            <p className="mx-auto mt-2 max-w-md text-sm leading-6 text-gray-500">
+              Create your first property listing. It will stay available in this browser after a reload.
+            </p>
+            <a
+              className="mt-6 inline-flex items-center gap-2 rounded-lg bg-[#3f4852] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#333b43]"
+              href="/exposes/new"
+            >
+              <LuCirclePlus aria-hidden="true" />
+              Create a listing
+            </a>
+          </div>
+        )}
+      </section>
+    </main>
+  );
+}
