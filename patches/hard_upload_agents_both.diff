index 0000000..3666f76
--- /dev/null
+++ b/app/components/image-upload.tsx
@@ -0,0 +1,218 @@
+import { useRef, useState } from 'react';
+import {
+  LuArrowLeft,
+  LuArrowRight,
+  LuImagePlus,
+  LuStar,
+  LuTrash2,
+  LuUpload,
+} from 'react-icons/lu';
+import type { UploadImage } from '../data/properties';
+
+const ACCEPTED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];
+const MAX_FILE_SIZE = 5 * 1024 * 1024;
+const MAX_IMAGES = 8;
+
+interface ImageUploadProps {
+  images: UploadImage[];
+  onChange: (images: UploadImage[]) => void;
+}
+
+function readFile(file: File) {
+  return new Promise<string>((resolve, reject) => {
+    const reader = new FileReader();
+    reader.onload = () => resolve(String(reader.result));
+    reader.onerror = () => reject(new Error(`Could not read ${file.name}.`));
+    reader.readAsDataURL(file);
+  });
+}
+
+export default function ImageUpload({ images, onChange }: ImageUploadProps) {
+  const inputRef = useRef<HTMLInputElement>(null);
+  const [error, setError] = useState('');
+  const [dragging, setDragging] = useState(false);
+
+  const addFiles = async (files: File[]) => {
+    setError('');
+    const remainingSlots = MAX_IMAGES - images.length;
+
+    if (remainingSlots <= 0) {
+      setError('You can upload up to 8 images.');
+      return;
+    }
+
+    const validFiles: File[] = [];
+    for (const file of files) {
+      if (!ACCEPTED_TYPES.includes(file.type)) {
+        setError('Only JPG, PNG, and WebP images are supported.');
+        continue;
+      }
+      if (file.size > MAX_FILE_SIZE) {
+        setError(`${file.name} is larger than 5 MB.`);
+        continue;
+      }
+      validFiles.push(file);
+    }
+
+    if (validFiles.length > remainingSlots) {
+      setError(`Only ${remainingSlots} more image${remainingSlots === 1 ? '' : 's'} can be added.`);
+    }
+
+    try {
+      const selectedFiles = validFiles.slice(0, remainingSlots);
+      const dataUrls = await Promise.all(selectedFiles.map(readFile));
+      onChange([
+        ...images,
+        ...selectedFiles.map((file, index) => ({
+          id: crypto.randomUUID(),
+          name: file.name,
+          dataUrl: dataUrls[index],
+        })),
+      ]);
+    } catch (readError) {
+      setError(readError instanceof Error ? readError.message : 'Images could not be read.');
+    }
+  };
+
+  const moveImage = (index: number, direction: -1 | 1) => {
+    const targetIndex = index + direction;
+    if (targetIndex < 0 || targetIndex >= images.length) return;
+    const reordered = [...images];
+    [reordered[index], reordered[targetIndex]] = [
+      reordered[targetIndex],
+      reordered[index],
+    ];
+    onChange(reordered);
+  };
+
+  const makeCover = (index: number) => {
+    const reordered = [...images];
+    const [cover] = reordered.splice(index, 1);
+    reordered.unshift(cover);
+    onChange(reordered);
+  };
+
+  return (
+    <div>
+      <button
+        className={`flex w-full flex-col items-center justify-center rounded-2xl border-2 border-dashed px-6 py-12 text-center transition ${
+          dragging
+            ? 'border-[#167f73] bg-[#3df5dc]/10'
+            : 'border-gray-300 bg-gray-50 hover:border-gray-400'
+        }`}
+        type="button"
+        onClick={() => inputRef.current?.click()}
+        onDragEnter={(event) => {
+          event.preventDefault();
+          setDragging(true);
+        }}
+        onDragOver={(event) => event.preventDefault()}
+        onDragLeave={() => setDragging(false)}
+        onDrop={(event) => {
+          event.preventDefault();
+          setDragging(false);
+          void addFiles(Array.from(event.dataTransfer.files));
+        }}
+      >
+        <span className="flex h-14 w-14 items-center justify-center rounded-full bg-white text-[#167f73] shadow-sm">
+          {dragging ? <LuUpload size="25" /> : <LuImagePlus size="25" />}
+        </span>
+        <span className="mt-4 font-semibold text-gray-900">
+          Drop property images here
+        </span>
+        <span className="mt-1 text-sm text-gray-500">
+          or click to browse JPG, PNG, or WebP files
+        </span>
+        <span className="mt-3 text-xs text-gray-400">
+          Up to 8 images, 5 MB each
+        </span>
+      </button>
+
+      <input
+        ref={inputRef}
+        className="sr-only"
+        type="file"
+        accept={ACCEPTED_TYPES.join(',')}
+        multiple
+        onChange={(event) => {
+          void addFiles(Array.from(event.target.files ?? []));
+          event.target.value = '';
+        }}
+        aria-label="Choose property images"
+      />
+
+      {error && (
+        <p className="mt-3 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700" role="alert">
+          {error}
+        </p>
+      )}
+
+      {images.length > 0 && (
+        <div className="mt-6 grid gap-4 sm:grid-cols-2">
+          {images.map((image, index) => (
+            <article
+              className="overflow-hidden rounded-xl border border-gray-200 bg-white"
+              key={image.id}
+            >
+              <div className="relative">
+                <img
+                  className="h-44 w-full object-cover"
+                  src={image.dataUrl}
+                  alt={`Upload preview: ${image.name}`}
+                />
+                {index === 0 && (
+                  <span className="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full bg-[#3df5dc] px-3 py-1 text-xs font-semibold text-gray-950">
+                    <LuStar aria-hidden="true" />
+                    Cover
+                  </span>
+                )}
+              </div>
+              <div className="p-3">
+                <p className="truncate text-sm font-medium text-gray-800">{image.name}</p>
+                <div className="mt-3 flex flex-wrap gap-2">
+                  {index > 0 && (
+                    <button
+                      className="rounded-lg border border-gray-200 p-2 text-gray-600 transition hover:bg-gray-50"
+                      type="button"
+                      onClick={() => moveImage(index, -1)}
+                      aria-label={`Move ${image.name} left`}
+                    >
+                      <LuArrowLeft aria-hidden="true" />
+                    </button>
+                  )}
+                  {index < images.length - 1 && (
+                    <button
+                      className="rounded-lg border border-gray-200 p-2 text-gray-600 transition hover:bg-gray-50"
+                      type="button"
+                      onClick={() => moveImage(index, 1)}
+                      aria-label={`Move ${image.name} right`}
+                    >
+                      <LuArrowRight aria-hidden="true" />
+                    </button>
+                  )}
+                  {index > 0 && (
+                    <button
+                      className="rounded-lg border border-gray-200 px-3 py-2 text-xs font-medium text-gray-700 transition hover:bg-gray-50"
+                      type="button"
+                      onClick={() => makeCover(index)}
+                    >
+                      Set as cover
+                    </button>
+                  )}
+                  <button
+                    className="ml-auto rounded-lg border border-red-100 p-2 text-red-600 transition hover:bg-red-50"
+                    type="button"
+                    onClick={() => onChange(images.filter((entry) => entry.id !== image.id))}
+                    aria-label={`Remove ${image.name}`}
+                  >
+                    <LuTrash2 aria-hidden="true" />
+                  </button>
+                </div>
+              </div>
+            </article>
+          ))}
+        </div>
+      )}
+    </div>
+  );
+}
