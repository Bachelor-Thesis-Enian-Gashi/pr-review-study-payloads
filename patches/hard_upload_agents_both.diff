+                    className={inputClasses}
+                    value={form.address}
+                    onChange={(event) => updateField('address', event.target.value)}
+                    placeholder="Street 10, 10115 Berlin"
+                    maxLength={160}
+                  />
+                </Field>
+                <Field
+                  label="Property description"
+                  error={errors.description}
+                  className="sm:col-span-2"
+                >
+                  <textarea
