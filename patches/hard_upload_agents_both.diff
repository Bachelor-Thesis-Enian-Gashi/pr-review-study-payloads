+                    placeholder="Bright apartment with city views"
+                    maxLength={100}
+                  />
+                </Field>
+                <Field label="Property type">
+                  <select
+                    className={inputClasses}
+                    value={form.type}
+                    onChange={(event) => updateField('type', event.target.value)}
+                  >
+                    {propertyTypes.map((type) => (
+                      <option key={type}>{type}</option>
+                    ))}
+                  </select>
