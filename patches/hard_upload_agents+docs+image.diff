+                type="button"
+                onClick={() => setStep((current) => current - 1)}
+                disabled={publishing}
+              >
+                <LuArrowLeft aria-hidden="true" />
+                Back
+              </button>
+            ) : (
+              <a className="text-sm font-medium text-gray-500 hover:text-gray-900" href="/exposes">
+                Cancel
+              </a>
+            )}
+
+            {step < steps.length - 1 ? (
+              <button
+                className="inline-flex items-center gap-2 rounded-lg bg-[#3f4852] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#333b43]"
+                type="button"
+                onClick={goForward}
+              >
+                Continue
+                <LuArrowRight aria-hidden="true" />
+              </button>
+            ) : (
+              <button
+                className="inline-flex items-center gap-2 rounded-lg bg-[#3df5dc] px-6 py-3 text-sm font-semibold text-gray-950 transition hover:bg-[#2de0ca] disabled:cursor-wait disabled:opacity-60"
+                type="button"
+                onClick={() => void publish()}
+                disabled={publishing}
+              >
+                <LuCheck aria-hidden="true" />
+                {publishing ? 'Publishing…' : 'Publish listing'}
+              </button>
+            )}
+          </div>
+        </form>
+      </div>
+    </main>
+  );
+}
+
+const inputClasses =
+  'w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 outline-none transition focus:border-[#167f73] focus:ring-2 focus:ring-[#3df5dc]/25';
+
+function StepHeading({ title, description }: { title: string; description: string }) {
+  return (
+    <div>
+      <h2 className="text-2xl font-semibold text-gray-950">{title}</h2>
+      <p className="mt-2 text-sm text-gray-500">{description}</p>
+    </div>
+  );
+}
+
+function Field({
+  label,
+  error,
+  className = '',
+  children,
+}: {
+  label: string;
+  error?: string;
+  className?: string;
+  children: React.ReactNode;
+}) {
+  return (
+    <label className={`block ${className}`}>
+      <span className="mb-2 block text-sm font-medium text-gray-700">{label}</span>
+      {children}
+      {error && <span className="mt-2 block text-sm text-red-600">{error}</span>}
+    </label>
+  );
+}
+
+function NumberField({
+  label,
+  value,
+  onChange,
+  error,
+  suffix,
+  min,
+  step = '1',
+}: {
+  label: string;
+  value: string;
+  onChange: (value: string) => void;
+  error?: string;
+  suffix?: string;
+  min: string;
+  step?: string;
+}) {
+  return (
+    <Field label={label} error={error}>
+      <span className="flex items-center rounded-lg border border-gray-200 bg-gray-50 focus-within:border-[#167f73] focus-within:ring-2 focus-within:ring-[#3df5dc]/25">
+        <input
+          className="min-w-0 flex-1 bg-transparent px-4 py-3 text-sm text-gray-900 outline-none"
+          type="number"
+          min={min}
+          step={step}
+          value={value}
+          onChange={(event) => onChange(event.target.value)}
+        />
+        {suffix && <span className="pr-4 text-sm text-gray-400">{suffix}</span>}
+      </span>
+    </Field>
+  );
+}
+
+function PreviewFact({ value, label }: { value: string; label: string }) {
+  return (
+    <div>
+      <p className="font-semibold text-gray-950">{value}</p>
+      <p className="mt-1 text-xs text-gray-500">{label}</p>
+    </div>
+  );
+}
