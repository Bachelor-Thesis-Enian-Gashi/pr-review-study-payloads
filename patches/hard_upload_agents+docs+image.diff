+++ b/app/src/routes/CreateExpose.tsx
@@ -0,0 +1,525 @@
+import { useState } from 'react';
+import {
+  LuArrowLeft,
+  LuArrowRight,
+  LuCheck,
+  LuCircleCheck,
+  LuHousePlus,
+  LuImages,
+} from 'react-icons/lu';
+import { useNavigate } from 'react-router-dom';
+import ImageUpload from '../../components/image-upload';
+import Navbar from '../../components/navbar';
+import {
+  createLocalProperty,
+  type LocalPropertyInput,
+} from '../../data/property-store';
+import { getPropertySlug, type UploadImage } from '../../data/properties';
+
+const steps = ['Basics', 'Details', 'Images', 'Preview'];
+const propertyTypes = ['Apartment', 'House', 'Loft', 'Penthouse', 'Studio'];
+
+interface FormState {
+  name: string;
+  rentWarm: string;
+  size: string;
+  rooms: string;
+  address: string;
+  description: string;
+  type: string;
+  floor: string;
+  availableFrom: string;
+  petsAllowed: boolean;
+  internetSpeed: string;
+}
+
+const initialForm: FormState = {
+  name: '',
+  rentWarm: '',
+  size: '',
+  rooms: '',
+  address: '',
+  description: '',
+  type: 'Apartment',
+  floor: '0',
+  availableFrom: '',
+  petsAllowed: false,
+  internetSpeed: '',
+};
+
+function today() {
+  const date = new Date();
+  const offset = date.getTimezoneOffset();
+  return new Date(date.getTime() - offset * 60_000).toISOString().slice(0, 10);
+}
+
+export default function CreateExpose() {
+  const navigate = useNavigate();
+  const [step, setStep] = useState(0);
+  const [form, setForm] = useState(initialForm);
+  const [images, setImages] = useState<UploadImage[]>([]);
+  const [errors, setErrors] = useState<Record<string, string>>({});
+  const [submitError, setSubmitError] = useState('');
+  const [publishing, setPublishing] = useState(false);
+
+  const updateField = <K extends keyof FormState>(field: K, value: FormState[K]) => {
+    setForm((current) => ({ ...current, [field]: value }));
+    setErrors((current) => ({ ...current, [field]: '' }));
+  };
+
+  const validateStep = (stepToValidate: number) => {
+    const nextErrors: Record<string, string> = {};
+
+    if (stepToValidate === 0) {
+      if (form.name.trim().length < 8) {
+        nextErrors.name = 'Use at least 8 characters for the listing title.';
+      }
+      if (!form.address.includes(',') || form.address.trim().length < 10) {
+        nextErrors.address = 'Enter a complete address including city.';
+      }
+      if (form.description.trim().length < 40) {
+        nextErrors.description = 'Describe the property in at least 40 characters.';
+      }
+    }
+
+    if (stepToValidate === 1) {
+      const numericChecks = [
+        ['rentWarm', Number(form.rentWarm), 1, 100_000],
+        ['size', Number(form.size), 1, 10_000],
+        ['rooms', Number(form.rooms), 1, 100],
+        ['floor', Number(form.floor), 0, 200],
+        ['internetSpeed', Number(form.internetSpeed), 1, 100_000],
+      ] as const;
+
+      numericChecks.forEach(([field, value, minimum, maximum]) => {
+        if (!Number.isFinite(value) || value < minimum || value > maximum) {
+          nextErrors[field] = `Enter a value between ${minimum} and ${maximum.toLocaleString('en-US')}.`;
+        }
+      });
+
+      if (!form.availableFrom || form.availableFrom < today()) {
+        nextErrors.availableFrom = 'Choose today or a future date.';
+      }
+    }
+
+    if (stepToValidate === 2 && images.length === 0) {
+      nextErrors.images = 'Add at least one property image.';
+    }
+
+    setErrors(nextErrors);
+    return Object.keys(nextErrors).length === 0;
+  };
+
+  const goForward = () => {
+    if (!validateStep(step)) return;
+    setStep((current) => Math.min(current + 1, steps.length - 1));
+    window.scrollTo({ top: 0, behavior: 'smooth' });
+  };
+
+  const publish = async () => {
+    if (publishing) return;
+    setPublishing(true);
+    setSubmitError('');
+
+    const imageData = images.map((image) => image.dataUrl);
+    const property: LocalPropertyInput = {
+      name: form.name.trim(),
+      rent_warm: Number(form.rentWarm),
+      size_m2: Number(form.size),
+      rooms: Number(form.rooms),
+      address: form.address.trim(),
+      main_image: imageData[0],
+      images: imageData,
+      description: form.description.trim(),
+      type: form.type,
+      floor: Number(form.floor),
+      available_for_pickup_starting: form.availableFrom,
+      pets_allowed: form.petsAllowed,
+      internet_speed_mbit: Number(form.internetSpeed),
+    };
+
+    try {
+      const createdProperty = await createLocalProperty(property);
+      navigate(`/exposes/${getPropertySlug(createdProperty)}`);
+    } catch (error) {
+      setSubmitError(
+        error instanceof Error ? error.message : 'The listing could not be published.',
+      );
+      setPublishing(false);
+    }
+  };
+
+  return (
+    <main className="min-h-screen bg-[#f4f6f7]">
+      <Navbar resultsPage />
+
+      <div className="mx-auto max-w-4xl px-5 py-8 sm:px-8 sm:py-12">
+        <div className="mb-8 flex items-start gap-4">
+          <span className="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#3df5dc]/25 text-[#167f73]">
+            <LuHousePlus size="24" aria-hidden="true" />
+          </span>
+          <div>
+            <h1 className="text-3xl font-semibold text-gray-950">List a property</h1>
+            <p className="mt-2 text-gray-500">
+              Create a polished rental listing stored securely in this browser.
+            </p>
+          </div>
+        </div>
+
+        <ol className="mb-8 grid grid-cols-4 gap-2" aria-label="Listing progress">
+          {steps.map((label, index) => (
+            <li key={label}>
+              <div
+                className={`h-1.5 rounded-full ${
+                  index <= step ? 'bg-[#167f73]' : 'bg-gray-200'
+                }`}
+              />
+              <p
+                className={`mt-2 text-xs font-medium ${
+                  index === step ? 'text-gray-900' : 'text-gray-400'
+                }`}
+                aria-current={index === step ? 'step' : undefined}
+              >
+                {index + 1}. {label}
+              </p>
+            </li>
+          ))}
+        </ol>
+
+        <form
+          className="rounded-2xl bg-white p-6 shadow-sm sm:p-9"
+          onSubmit={(event) => event.preventDefault()}
+        >
+          {step === 0 && (
+            <section>
+              <StepHeading
+                title="Tell us about the property"
+                description="Start with the details renters use to identify your listing."
+              />
+              <div className="mt-8 grid gap-6 sm:grid-cols-2">
+                <Field label="Listing title" error={errors.name} className="sm:col-span-2">
+                  <input
+                    className={inputClasses}
+                    value={form.name}
+                    onChange={(event) => updateField('name', event.target.value)}
+                    placeholder="Bright apartment with city views"
+                    maxLength={100}
+                  />
+                </Field>
+                <Field label="Property type">
+                  <select
+                    className={inputClasses}
+                    value={form.type}
+                    onChange={(event) => updateField('type', event.target.value)}
+                  >
+                    {propertyTypes.map((type) => (
+                      <option key={type}>{type}</option>
+                    ))}
+                  </select>
+                </Field>
+                <Field label="Full address" error={errors.address}>
+                  <input
+                    className={inputClasses}
+                    value={form.address}
+                    onChange={(event) => updateField('address', event.target.value)}
+                    placeholder="Street 10, 10115 Berlin"
+                    maxLength={160}
+                  />
+                </Field>
+                <Field
+                  label="Property description"
+                  error={errors.description}
+                  className="sm:col-span-2"
+                >
+                  <textarea
+                    className={`${inputClasses} min-h-36 resize-y`}
+                    value={form.description}
+                    onChange={(event) => updateField('description', event.target.value)}
+                    placeholder="Describe the layout, location, condition, and highlights."
+                    maxLength={1500}
+                  />
+                  <span className="mt-2 block text-right text-xs text-gray-400">
+                    {form.description.length}/1500
+                  </span>
+                </Field>
+              </div>
+            </section>
+          )}
+
+          {step === 1 && (
+            <section>
+              <StepHeading
+                title="Add rental details"
+                description="Provide accurate figures and availability information."
+              />
+              <div className="mt-8 grid gap-6 sm:grid-cols-2">
+                <NumberField
+                  label="Monthly warm rent"
+                  value={form.rentWarm}
+                  onChange={(value) => updateField('rentWarm', value)}
+                  error={errors.rentWarm}
+                  suffix="€"
+                  min="1"
+                />
+                <NumberField
+                  label="Living space"
+                  value={form.size}
+                  onChange={(value) => updateField('size', value)}
+                  error={errors.size}
+                  suffix="m²"
+                  min="1"
+                  step="0.1"
+                />
+                <NumberField
+                  label="Rooms"
+                  value={form.rooms}
+                  onChange={(value) => updateField('rooms', value)}
+                  error={errors.rooms}
+                  min="1"
+                  step="0.5"
+                />
+                <NumberField
+                  label="Floor"
+                  value={form.floor}
+                  onChange={(value) => updateField('floor', value)}
+                  error={errors.floor}
+                  min="0"
+                />
+                <Field label="Available from" error={errors.availableFrom}>
+                  <input
+                    className={inputClasses}
+                    type="date"
+                    min={today()}
+                    value={form.availableFrom}
+                    onChange={(event) => updateField('availableFrom', event.target.value)}
+                  />
+                </Field>
+                <NumberField
+                  label="Internet speed"
+                  value={form.internetSpeed}
+                  onChange={(value) => updateField('internetSpeed', value)}
+                  error={errors.internetSpeed}
+                  suffix="Mbit/s"
+                  min="1"
+                />
+                <Field label="Pets" className="sm:col-span-2">
+                  <label className="flex cursor-pointer items-center gap-3 rounded-xl border border-gray-200 bg-gray-50 p-4">
+                    <input
+                      className="h-4 w-4 accent-[#167f73]"
+                      type="checkbox"
+                      checked={form.petsAllowed}
+                      onChange={(event) => updateField('petsAllowed', event.target.checked)}
+                    />
+                    <span className="text-sm text-gray-700">Pets are allowed at this property</span>
+                  </label>
+                </Field>
+              </div>
+            </section>
+          )}
+
+          {step === 2 && (
+            <section>
+              <StepHeading
+                title="Show the property"
+                description="Add 1–8 images. The first image becomes the listing cover."
+              />
+              <div className="mt-8">
+                <details className="mb-6 overflow-hidden rounded-xl border border-gray-200 bg-gray-50">
+                  <summary className="cursor-pointer px-5 py-4 text-sm font-semibold text-gray-800 marker:text-[#167f73]">
+                    Image upload guide
+                  </summary>
+                  <div className="border-t border-gray-200 bg-white p-4">
+                    <p className="mb-4 text-sm leading-6 text-gray-600">
+                      Use the first image as the cover, arrange the remaining
+                      photos in viewing order, and remove unsuitable images
+                      before continuing.
+                    </p>
+                    <img
+                      className="w-full rounded-lg border border-gray-200"
