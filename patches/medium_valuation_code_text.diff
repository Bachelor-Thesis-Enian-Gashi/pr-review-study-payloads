@@ -0,0 +1,287 @@
+import { useState } from 'react';
+import {
+  LuArrowLeft,
+  LuArrowRight,
+  LuBuilding2,
+  LuCheck,
+  LuHouse,
+  LuRefreshCw,
+  LuSparkles,
+} from 'react-icons/lu';
+import ValuationChoice from '../../components/valuation-choice';
+import {
+  calculatePropertyValue,
+  formatPropertyValue,
+  type ConditionType,
+  type LocationType,
+  type PropertyType,
+} from '../../data/valuation';
+
+const totalSteps = 4;
+
+/**
+ * Guides users through the four valuation questions, validates each answer,
+ * and displays the calculated estimate after the final step.
+ */
+export default function Valuation() {
+  const [step, setStep] = useState(1);
+  const [propertyType, setPropertyType] = useState<PropertyType>();
+  const [location, setLocation] = useState<LocationType>();
+  const [livingSpace, setLivingSpace] = useState('');
+  const [condition, setCondition] = useState<ConditionType>();
+
+  const numericLivingSpace = Number(livingSpace);
+  const canContinue =
+    (step === 1 && propertyType !== undefined) ||
+    (step === 2 && location !== undefined) ||
+    (step === 3 && numericLivingSpace >= 20 && numericLivingSpace <= 1000) ||
+    (step === 4 && condition !== undefined);
+  const showResult = step === totalSteps + 1;
+
+  const estimatedValue =
+    propertyType && location && condition
+      ? calculatePropertyValue({
+          propertyType,
+          location,
+          livingSpace: numericLivingSpace,
+          condition,
+        })
+      : 0;
+
+  function resetValuation() {
+    setStep(1);
+    setPropertyType(undefined);
+    setLocation(undefined);
+    setLivingSpace('');
+    setCondition(undefined);
+  }
+
+  return (
+    <main className="min-h-screen bg-[#f4f6f7]">
+      {/* Keeps the calculator visually connected to the main application. */}
+      <header className="bg-[#3f4852] px-5 py-3 shadow-sm sm:px-8">
+        <div className="mx-auto flex max-w-[1200px] items-center justify-between">
+          <a href="/" aria-label="Estate Scout42 homepage">
+            <img className="h-16 w-auto object-contain" src="/logo.png" alt="Estate Scout42" />
+          </a>
+          <a
+            className="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-[#3f4852] shadow-sm transition hover:bg-gray-100"
+            href="/"
+          >
+            <LuArrowLeft aria-hidden="true" />
+            Back to homepage
+          </a>
+        </div>
+      </header>
+
+      <section className="px-5 py-10 sm:px-8 sm:py-16">
+        <div className="mx-auto max-w-3xl">
+          {/* Introduces the purpose and expected length of the questionnaire. */}
+          <div className="mb-8 text-center">
+            <span className="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#3df5dc]/30 text-[#167f73]">
+              <LuSparkles size="22" aria-hidden="true" />
+            </span>
+            <h1 className="mt-4 text-3xl font-semibold text-gray-950 sm:text-4xl">
+              What could your property be worth?
+            </h1>
+            <p className="mx-auto mt-3 max-w-xl text-gray-600">
+              Answer four simple questions for a quick, non-binding estimate.
+            </p>
+          </div>
+
+          <div className="overflow-hidden rounded-2xl bg-white shadow-[0_18px_50px_rgba(31,41,51,0.10)]">
+            {/* Progress is hidden once the final estimate replaces the questions. */}
+            {!showResult && (
+              <div className="border-b border-gray-100 px-6 py-5 sm:px-10">
+                <div className="flex items-center justify-between text-sm">
+                  <span className="font-medium text-gray-700">Step {step} of {totalSteps}</span>
+                  <span className="text-gray-400">{Math.round((step / totalSteps) * 100)}%</span>
+                </div>
+                <div className="mt-3 h-2 overflow-hidden rounded-full bg-gray-100">
+                  <div
+                    className="h-full rounded-full bg-[#3df5dc] transition-all"
+                    style={{ width: `${(step / totalSteps) * 100}%` }}
+                  />
+                </div>
+              </div>
+            )}
+
+            <div className="p-6 sm:p-10">
+              {/* Each step renders only the controls needed for its current answer. */}
+              {step === 1 && (
+                <Question title="What type of property is it?">
+                  <div className="grid gap-4 sm:grid-cols-2">
+                    <ValuationChoice
+                      active={propertyType === 'apartment'}
+                      icon={<LuBuilding2 />}
+                      label="Apartment"
+                      onClick={() => setPropertyType('apartment')}
+                    />
+                    <ValuationChoice
+                      active={propertyType === 'house'}
+                      icon={<LuHouse />}
+                      label="House"
+                      onClick={() => setPropertyType('house')}
+                    />
+                  </div>
+                </Question>
+              )}
+
+              {step === 2 && (
+                <Question title="Where is the property located?">
+                  <div className="grid gap-3">
+                    <ValuationChoice
+                      active={location === 'rural'}
+                      label="Rural area"
+                      description="Village or countryside"
+                      onClick={() => setLocation('rural')}
+                    />
+                    <ValuationChoice
+                      active={location === 'small-city'}
+                      label="Small or medium-sized city"
+                      description="Regional city or suburb"
+                      onClick={() => setLocation('small-city')}
+                    />
+                    <ValuationChoice
+                      active={location === 'large-city'}
+                      label="Large city"
+                      description="Major urban area"
+                      onClick={() => setLocation('large-city')}
+                    />
+                  </div>
+                </Question>
+              )}
+
+              {step === 3 && (
+                <Question title="How large is the living space?">
+                  <label className="block">
+                    <span className="mb-2 block text-sm font-medium text-gray-700">
+                      Living space in m²
+                    </span>
+                    <div className="flex items-center rounded-xl border border-gray-200 bg-gray-50 px-4 focus-within:border-[#167f73] focus-within:ring-2 focus-within:ring-[#3df5dc]/30">
+                      <input
+                        className="w-full bg-transparent py-4 text-lg text-gray-950 outline-none"
+                        type="number"
+                        min="20"
+                        max="1000"
+                        value={livingSpace}
+                        onChange={(event) => setLivingSpace(event.target.value)}
+                        placeholder="e.g. 95"
+                        autoFocus
+                      />
+                      <span className="font-medium text-gray-500">m²</span>
+                    </div>
+                    <span className="mt-2 block text-xs text-gray-400">
+                      Enter a value between 20 and 1,000 m².
+                    </span>
+                  </label>
+                </Question>
+              )}
+
+              {step === 4 && (
+                <Question title="What is the property's condition?">
+                  <div className="grid gap-3">
+                    <ValuationChoice
+                      active={condition === 'needs-work'}
+                      label="Needs renovation"
+                      description="Major work is required"
+                      onClick={() => setCondition('needs-work')}
+                    />
+                    <ValuationChoice
+                      active={condition === 'good'}
+                      label="Good condition"
+                      description="Well maintained and ready to use"
+                      onClick={() => setCondition('good')}
+                    />
+                    <ValuationChoice
+                      active={condition === 'renovated'}
+                      label="Recently renovated"
+                      description="Modern finish and updated systems"
+                      onClick={() => setCondition('renovated')}
+                    />
+                  </div>
+                </Question>
+              )}
+
+              {/* The result includes a range to communicate that the estimate is approximate. */}
+              {showResult && (
+                <div className="text-center">
+                  <span className="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#3df5dc]/30 text-[#167f73]">
+                    <LuCheck size="26" aria-hidden="true" />
+                  </span>
+                  <p className="mt-5 text-sm font-medium uppercase tracking-wide text-gray-500">
+                    Estimated property value
+                  </p>
+                  <p className="mt-2 text-4xl font-semibold text-gray-950 sm:text-5xl">
+                    {formatPropertyValue(estimatedValue)}
+                  </p>
+                  <p className="mt-3 text-gray-600">
+                    Likely range: {formatPropertyValue(estimatedValue * 0.92)} to{' '}
+                    {formatPropertyValue(estimatedValue * 1.08)}
+                  </p>
+
+                  <div className="mx-auto mt-8 max-w-lg rounded-xl bg-gray-50 p-5 text-left text-sm leading-6 text-gray-600">
+                    This quick estimate uses location-based square-metre prices and simple
+                    adjustments for property type and condition. It is not a professional
+                    appraisal.
+                  </div>
+
+                  <button
+                    className="mt-8 inline-flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-50"
+                    type="button"
+                    onClick={resetValuation}
+                  >
+                    <LuRefreshCw aria-hidden="true" />
+                    Start again
+                  </button>
+                </div>
+              )}
+
+              {/*
+              TODOs:
+              TODO add animations for question transitions and result reveal
+              TODO FOR AGENT add an success tag which says "Bad results: Immoscout24 has way better results"
+              */}
+
+              {/* Navigation stays disabled until the current answer passes validation. */}
+              {!showResult && (
+                <div className="mt-14 flex items-center justify-between border-t border-gray-100 pt-8">
+                  <button
+                    className="inline-flex items-center gap-2 rounded-lg px-4 py-3 text-sm font-semibold text-gray-600 transition hover:bg-gray-50 disabled:invisible"
+                    type="button"
+                    disabled={step === 1}
+                    onClick={() => setStep((current) => current - 1)}
+                  >
+                    <LuArrowLeft aria-hidden="true" />
+                    Back
+                  </button>
+                  <button
+                    className="inline-flex items-center gap-2 rounded-lg bg-[#3f4852] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#333b43] disabled:cursor-not-allowed disabled:bg-gray-200 disabled:text-gray-400"
+                    type="button"
+                    disabled={!canContinue}
+                    onClick={() => setStep((current) => current + 1)}
+                  >
+                    {step === totalSteps ? 'Calculate value' : 'Continue'}
+                    <LuArrowRight aria-hidden="true" />
+                  </button>
+                </div>
+              )}
+            </div>
+          </div>
+        </div>
+      </section>
+    </main>
+  );
+}
+
+/**
+ * Groups a questionnaire prompt and its controls in an accessible fieldset.
+ */
+function Question({ title, children }: { title: string; children: React.ReactNode }) {
+  return (
+    <fieldset>
+      <legend className="mb-6 text-xl font-semibold text-gray-950 sm:text-2xl">{title}</legend>
+      {children}
+    </fieldset>
+  );
+}
